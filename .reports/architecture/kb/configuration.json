  "propagation": {
   "daemon": "re-reads .env with override=True AND rebuilds Config EVERY TICK (cli.py:1303-1304). A go_live write reaches the daemon within one tick.",
   "studio": "load_dotenv ONCE at process entry (cli.py:795), then blocks in app.run. A .env change made by the CLI or daemon NEVER reaches a running Studio (COUP-02b).",
   "secrets": "keyring-first. Reads fail OPEN; writes fail CLOSED (set_secret round-trips the value back and raises OSError if it does not persist \u2014 load-bearing, because the caller then scrubs the .env fallback)."
  },
  "writers": {
   "FANOPS_LIVE": "golive._dual_write ONLY (INV-18, AST-confirmed: exactly 2 os.environ[...] assignment sites in src/ \u2014 golive.py:66 (dynamic key) and autopilot.py:80 (FANOPS_RESPONDER))."
  }
