{
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff check:*)",
      "Bash(pip install -e:*)"
    ],
    "deny": [
      "Bash(black:*)",
      "Bash(ruff format:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)",
      "Bash(* > /dev/*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/hookify-run.py\"",
            "timeout": 15,
            "description": "Vendored hookify runner: evaluates .claude/hookify.*.local.md (no plugin dependency)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-completion-gate.py\"",
            "timeout": 180,
            "description": "Completion-gate: refuse to end a turn while ruff/fast-pytest is red, a stub sits in added lines, a claim lacks evidence, or scope was silently narrowed (3-strike breaker; FANOPS_STOP_GATE=0 disables)"
          }
        ]
      }
    ]
  }
}
