{
  "env": {
    "ECC_HOOK_PROFILE": "standard",
    "ECC_GATEGUARD": "on",
    "GATEGUARD_DISABLED": "0",
    "ECC_DISABLED_HOOKS": "pre:mcp-health-check,pre:observe:continuous-learning,pre:edit-write:suggest-compact,post:observe:continuous-learning,post:mcp-health-check,post:edit:accumulator,stop:evaluate-session,stop:cost-tracker,post:ecc-context-monitor,post:session-activity-tracker,post:ecc-metrics-bridge"
  },
  "permissions": {
    "allow": [
      "Bash(ruff check:*)",
      "Bash(pip install -e:*)"
    ],
    "deny": [
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(./scripts/check-full.sh:*)",
      "Bash(black:*)",
      "Bash(ruff format:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)",
      "Bash(* > /dev/*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-hedge-on-stop.py\"",
            "timeout": 10,
            "description": "Blocks the turn from ending when the final message carries hedge/deflection/half-measure tells — forces a rewrite"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/anti-divert-contract.py\"",
            "timeout": 10,
            "description": "Short execute-first contract (JSON) — blocks operator handoffs and unprompted backlog shipping"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/hookify-run.py\"",
            "timeout": 15,
            "description": "Vendored hookify runner: evaluates .claude/hookify.*.local.md (no plugin dependency)"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/decide_dont_ask.py\"",
            "timeout": 10,
            "description": "Blocks a DUMB question (re-asking the brief, reduced-ambition options, rule-governed, or asked with no decision-work) by correlating against this turn's transcript — a real fork survives"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/orchestration_gate_claude.py\"",
            "timeout": 45,
            "description": "FanOps orchestration gate (land-gate, protected paths, destructive git, operator-only stop) — inert unless a wave is engaged"
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/orchestration_gate_claude.py\"",
            "timeout": 15,
            "description": "FanOps spawn allowlist + attribution ledger; fanops-orchestrator-as-subagent denied unconditionally with a take-over redirect"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/orchestration_gate_claude.py\"",
            "timeout": 15,
            "description": "FanOps wave write-protection: verification records writable only by fanops-worker; orchestration state + enforcement machinery not writable at all — inert outside waves"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/orchestration_gate_claude.py\"",
            "timeout": 15,
            "description": "FanOps attribution ledger: records each sub-agent's completion during a wave"
          }
        ]
      }
    ]
  }
}
