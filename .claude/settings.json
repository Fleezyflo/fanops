{
  "env": {
    "ECC_HOOK_PROFILE": "standard",
    "ECC_GATEGUARD": "off",
    "GATEGUARD_DISABLED": "1",
    "ECC_DISABLED_HOOKS": "pre:edit-write:gateguard-fact-force,pre:bash:gateguard-fact-force,pre:edit-write:suggest-compact,pre:observe:continuous-learning,post:observe:continuous-learning,pre:mcp-health-check,post:mcp-health-check,post:edit:design-quality-check,post:edit:console-warn,post:edit:accumulator,stop:format-typecheck,stop:check-console-log,stop:evaluate-session,stop:cost-tracker,post:ecc-context-monitor,pre:governance-capture,post:governance-capture,post:session-activity-tracker,post:ecc-metrics-bridge"
  },
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff check:*)",
      "Bash(pip install -e:*)"
    ],
    "deny": [
      "Bash(black:*)",
      "Bash(ruff format:*)",
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(chmod 777:*)",
      "Bash(ssh:*)",
      "Bash(* > /dev/*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-hedge-on-stop.py\"",
            "timeout": 10,
            "description": "Blocks the turn from ending when the final message carries hedge/deflection/half-measure tells — forces a rewrite"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/anti-divert-contract.py\"",
            "timeout": 10,
            "description": "Short execute-first contract (JSON) — blocks operator handoffs and unprompted backlog shipping"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/hookify-run.py\"",
            "timeout": 15,
            "description": "Vendored hookify runner: evaluates .claude/hookify.*.local.md (no plugin dependency)"
          }
        ]
      }
    ]
  }
}
