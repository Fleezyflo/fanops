# secrets
.env
*.key
*-credentials.json
.mcp-credentials/

# media bank + agent IO + logs — large/private/regenerated, never committed
MohFlow-FanOps/01_inbox/*
MohFlow-FanOps/02_sources/*
MohFlow-FanOps/03_clips/*
MohFlow-FanOps/04_agent_io/*
MohFlow-FanOps/05_scheduled/*
MohFlow-FanOps/06_published/*
MohFlow-FanOps/07_reports/*
!MohFlow-FanOps/*/.gitkeep

# 00_control: regenerated runtime state holds PII (account_ids, transcripts, private
# filenames) — never commit. The tracked control files (accounts.json, RISK.md,
# RUNTIME.md, context.md, .gitkeep) are deliberately versioned and stay tracked.
MohFlow-FanOps/00_control/ledger.json
MohFlow-FanOps/00_control/ledger.lock
MohFlow-FanOps/00_control/ledger_digest.md
MohFlow-FanOps/00_control/run.log
# ledger snapshots/backups the operator writes around live runs (same PII as ledger.json) — never commit
MohFlow-FanOps/00_control/ledger.json.bak*
MohFlow-FanOps/00_control/ledger.json.pre*
MohFlow-FanOps/00_control/hashtag_budget.json

# python / venv
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.venv/
.coverage
.coverage.*
coverage.json

# review scratch
.fanops-*.json
.fanops-*.md
.fanops-*.js

# claude harness — keep workflows, ignore transient locks + ephemeral planning artifacts
.claude/scheduled_tasks.lock
.claude/plans/
.claude/prds/
.claude/PRPs/

# browser-QA / playwright scratch (screenshots, traces) — regenerated, never committed
.playwright-mcp/
.ui_audit/
/*.png

# git worktrees (isolated dev workspaces) — never tracked
.worktrees/

# macOS
.DS_Store

# superseded plans (kept on disk, not tracked)
2026-05-31-fanops-real-build.md
2026-05-31-mohflow-fanops.md

# Google OAuth client secret downloads (never commit)
client_secret_*.json
MohFlow-FanOps/00_control/accounts.json
MohFlow-FanOps/00_control/personas.json
MohFlow-FanOps/00_control/*.json
