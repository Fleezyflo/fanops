#!/usr/bin/env bash
set -euo pipefail

# ECC Codex Git Hook: pre-commit
# Blocks commits that add high-signal secrets.

if [[ "${ECC_SKIP_GIT_HOOKS:-0}" == "1" || "${ECC_SKIP_PRECOMMIT:-0}" == "1" ]]; then
  exit 0
fi

if [[ -f ".ecc-hooks-disable" || -f ".git/ecc-hooks-disable" ]]; then
  exit 0
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  exit 0
fi

staged_files="$(git diff --cached --name-only --diff-filter=ACMR || true)"
if [[ -z "$staged_files" ]]; then
  exit 0
fi

# Secret scan — shared with CI (MOL-193). scripts/scan-secrets.sh is the single source of the regexes +
# exclusions; the hook runs it in `staged` mode. (The ECC_SKIP_PRECOMMIT short-circuit above is the only
# local bypass; CI calls the script directly in `diff-base` mode and honors NO skip env.)
ROOT="$(git rev-parse --show-toplevel)"
if ! "$ROOT/scripts/scan-secrets.sh" staged; then
  echo "[ECC pre-commit] Commit blocked to prevent secret leakage — remove it (env vars / secret manager), re-stage, retry. Emergency bypass: ECC_SKIP_PRECOMMIT=1 git commit ..." >&2
  exit 1
fi

# --- Staged ruff: lint ONLY the staged .py files, fast (<10s). Not the whole tree — that's CI's job.
# Runs under the project venv (correct interpreter); silently skips if the venv is absent (the secret
# scan above already ran, so a missing venv degrades lint, never secret-blocking). No test execution.
ROOT="$(git rev-parse --show-toplevel)"
PY="$ROOT/.venv/bin/python"
staged_py="$(git diff --cached --name-only --diff-filter=ACMR -- '*.py' || true)"
if [[ -n "$staged_py" && -x "$PY" ]]; then
  # shellcheck disable=SC2086
  if ! "$PY" -m ruff check $staged_py; then
    echo "[fanops pre-commit] ruff failed on staged files — fix, re-stage, commit again." >&2
    exit 1
  fi
fi

# --- Scoped check.sh: when src/ or tests/ .py is staged, run the local gate (ruff + scoped pytest).
# BASE=HEAD scopes to this commit (staged + unstaged vs HEAD). Docs-only / scripts-only .py skip (fast path).
if printf '%s\n' "$staged_files" | rg -q '^(src|tests)/.+\.py$'; then
  if ! BASE=HEAD "$ROOT/scripts/check.sh"; then
    echo "[fanops pre-commit] check.sh failed — fix, re-stage, commit again." >&2
    exit 1
  fi
fi

exit 0
