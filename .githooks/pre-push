#!/usr/bin/env bash
set -euo pipefail
# FanOps repo-owned pre-push — POLICY GUARDS ONLY. No ruff, no pytest, no test execution of any kind.
# Hooks enforce policy; scripts run tests; CI proves everything. The full suite is CI's job (ci.yml,
# `unit` + `e2e`), the authoritative gate on every PR. Run tests locally BEFORE committing with
# `./scripts/check.sh` (scoped, fast) — this hook does NOT and will NOT run them.
#
# There is deliberately NO `FANOPS_SKIP_PREPUSH` / test-skip bypass: nothing here is skippable because
# nothing here is slow. The only override is the main-push escape below, which is a human-only lever.
#
# Wired via: git config --local core.hooksPath .githooks  (see README.md).

# --- GUARD: block direct pushes to main + force-pushes to main (AGENTS.md guardrail #1) ------------
# Enforced here because a markdown rule can't stop an unattended agent. A push updating
# refs/heads/main directly, or a NON-fast-forward (force) update to it, is refused outright.
# Deliberate main merges land via the GitHub PR flow (remote-side), not a local `git push origin main`.
# Bypass (human, deliberate only): FANOPS_ALLOW_MAIN_PUSH=1 git push ...
# git feeds ref specs on stdin exactly ONCE (local_ref local_sha remote_ref remote_sha).
while read -r _lref lsha rref rsha; do
  [[ -z "${rref:-}" ]] && continue
  [[ "$rref" != "refs/heads/main" ]] && continue
  if [[ "${FANOPS_ALLOW_MAIN_PUSH:-0}" != "1" ]]; then
    echo "[fanops pre-push] REFUSED: direct push to main is blocked. Open a PR and merge on green CI." >&2
    echo "[fanops pre-push] (deliberate human override: FANOPS_ALLOW_MAIN_PUSH=1 git push ...)" >&2
    exit 1
  fi
  # override in effect: still forbid a force (non-fast-forward) to main
  if [[ "${rsha:-}" != "0000000000000000000000000000000000000000" && -n "${lsha:-}" ]]; then
    if ! git merge-base --is-ancestor "$rsha" "$lsha" 2>/dev/null; then
      echo "[fanops pre-push] REFUSED: force-push to main (non-fast-forward) is blocked." >&2
      exit 1
    fi
  fi
done

# --- GUARD: lane file-ownership (AGENTS.md 'disjoint hot files' rule, now MECHANICAL) --------------
# OPT-IN by branch prefix: for a branch named after a lane (publish/, picking/, pick/, rfd/, ci/) this
# refuses a push that edits a hot file owned by a DIFFERENT lane (see .agents/lanes.json). For every
# other branch it is a no-op, so it never blocks cursor/*, bycreamco/mol-*, or human branches. Policy
# only — runs NO tests. FAILS OPEN on infra gaps (no venv/python, missing manifest/script): the guard
# is a fast structural check, not a correctness gate; CI (.github/workflows/lane-guard.yml) is the hard
# gate. Detected strays FAIL CLOSED. No skip env var — nothing here is slow.
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -n "$ROOT" && -f "$ROOT/scripts/lane_guard.py" && -f "$ROOT/.agents/lanes.json" ]]; then
  PY="$ROOT/.venv/bin/python"; [[ -x "$PY" ]] || PY="$(command -v python3 || true)"
  if [[ -n "$PY" ]]; then
    if ! "$PY" "$ROOT/scripts/lane_guard.py"; then
      echo "[fanops pre-push] REFUSED: lane file-ownership guard failed (see above)." >&2
      exit 1
    fi
  fi
fi

exit 0
