# FanOps environment — copy to `.env` and fill in. Keys are read at runtime via python-dotenv.
# Full reference: docs/CONFIG.md · first-run walkthrough: docs/RUNBOOK.md

# --- Publish backend (default: dryrun — writes payload JSON, posts nothing) ---
# Valid values: dryrun | postiz | zernio
# Per-channel routing in accounts.json is the source of truth; FANOPS_POSTER is a legacy bridge.
FANOPS_POSTER=dryrun

# --- Postiz (self-hosted IG publisher) ---
# Stand up Postiz per docs/POSTIZ_SETUP.md, then connect channels in the Postiz dashboard.
# POSTIZ_URL = your instance base (e.g. https://postiz.example.com)
# POSTIZ_API_KEY from Postiz → Settings → Developers → Public API (paste exactly; client trims whitespace only)
# Map each (handle × platform) to its Postiz integration id in accounts.json (Studio Go-Live tab).
# POSTIZ_URL=
# POSTIZ_API_KEY=

# --- Zernio (hosted TikTok publisher) ---
# Connect TikTok accounts inside Zernio's dashboard, then paste your API key here.
# ZERNIO_API_KEY=

# --- Live switch ---
# Set ONLY via Studio Go-Live (or manually for advanced setups). When 1, approved posts can publish live.
# FANOPS_LIVE=0

# --- Agent gates ---
# manual = human/cron writes response files; llm = pipeline answers gates via `claude -p` (subscription login)
FANOPS_RESPONDER=manual
# NOT required for llm mode: uses your existing `claude login` session — no ANTHROPIC_API_KEY needed.
# ANTHROPIC_API_KEY=

# --- Optional ---
# FANOPS_ARTIST_NAME=Moh Flow
# FANOPS_ZERNIO_MAX_UPLOAD_MB=4
